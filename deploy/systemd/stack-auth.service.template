[Unit]
Description=Stack auth server
After=network.target

[Service]
Type=simple
WorkingDirectory=__REMOTE_APP_DIR__
Environment=NODE_ENV=production
Environment=AUTH_HOST=127.0.0.1
Environment=AUTH_PORT=__AUTH_PORT__
Environment=STACK_DATA_DIR=__DATA_DIR__
ExecStart=__NODE_BIN__ __REMOTE_APP_DIR__/server/authserver.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
