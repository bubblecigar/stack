[Unit]
Description=Stack API server
After=network.target

[Service]
Type=simple
WorkingDirectory=__REMOTE_APP_DIR__
Environment=NODE_ENV=production
Environment=API_HOST=127.0.0.1
Environment=API_PORT=__API_PORT__
Environment=STACK_DATA_DIR=__DATA_DIR__
ExecStart=__NODE_BIN__ __REMOTE_APP_DIR__/server/apiserver.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
